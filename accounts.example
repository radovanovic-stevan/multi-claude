# claude-acct / claude-usage accounts
#
# This file lives at ~/.config/claude-acct/accounts (override with
# $CLAUDE_ACCT_CONFIG). The installer seeds it from accounts.example, and
# claude-acct writes a starter on first run — so just edit the entries below.
#
# One account per line:   <label>  <config_dir>  [email]
#   label       a short name you'll type, e.g. `claude-acct work`
#   config_dir  the CLAUDE_CONFIG_DIR for that account (~ and $HOME expand)
#   email       optional, shown for context only
#
# The first account listed is the "primary": its <config_dir>/skills folder is
# symlinked into the other accounts' config dirs so they share the same skills.
# Lines starting with # and blank lines are ignored.

work       ~/.claude            you@work.example
personal   ~/.claude-personal   you@personal.example
